{
	"name": "bmrcl-station-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node --env-file-if-exists=.env build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"serve": "pnpm build && node --env-file-if-exists=.env build",
		"receipts:matrix": "vite-node scripts/receiptMatrix.ts",
		"map-assets:build": "vite-node scripts/buildMapAssets.ts all",
		"basemap:build": "vite-node scripts/buildMapAssets.ts receipt",
		"wall-roads:build": "vite-node scripts/buildMapAssets.ts wall",
		"tiles:build": "bash scripts/tiles/build-tiles.sh",
		"viz:matrix": "vite-node scripts/vizMatrix.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@mapbox/vector-tile": "^2.0.3",
		"@sveltejs/adapter-node": "^5.5.6",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/d3-geo": "^3.1.0",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"@types/geojson": "^7946.0.16",
		"autoprefixer": "^10.4.20",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^2.46.1",
		"globals": "^15.14.0",
		"pbf": "^4.0.1",
		"playwright": "^1.61.1",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.10",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^6.0.0",
		"vite-node": "^3.0.0"
	},
	"dependencies": {
		"@deck.gl/core": "^9.1",
		"@deck.gl/geo-layers": "^9.1",
		"@deck.gl/layers": "^9.1",
		"@deck.gl/mapbox": "^9.1",
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"@fontsource/ibm-plex-sans": "^5.2.8",
		"@luma.gl/core": "^9.1",
		"@mapbox/polyline": "^1.2.1",
		"better-sqlite3": "^12.10.0",
		"d3-geo": "^3.1.1",
		"deck.gl": "^9.1",
		"h3-js": "^4.4.0",
		"maplibre-gl": "^5.1.0",
		"modern-screenshot": "^4.7.0",
		"pmtiles": "^4.4.1",
		"qrcode-generator": "^2.0.4"
	}
}
