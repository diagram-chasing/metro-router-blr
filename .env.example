# Copy to .env on the wall box to kill the last network deps. See INSTALL.md §2.

# ── Vector tiles ── pick ONE (both must be OpenMapTiles schema, not Protomaps).
# Option A — local pmtiles bundle dropped at static/tiles/bengaluru.pmtiles:
PUBLIC_TILES_URL=pmtiles:///tiles/bengaluru.pmtiles
# Option B — OpenFreeMap running locally on the box:
# PUBLIC_TILES_URL=http://localhost:8080/planet
# Unset → falls back to the public https://tiles.openfreemap.org/planet (needs internet).

# ── Glyphs ── self-hosted Plex stack in static/fonts/. Needed offline AND in prod
# builds (remote default serves Noto only, 404s on the Plex label font).
PUBLIC_GLYPHS_URL=/fonts/{fontstack}/{range}.pbf
